<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Daily Reading Log</title>
    
    <!-- 모바일 앱 설정 (홈 화면 추가 시 앱처럼 동작) -->
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="apple-mobile-web-app-title" content="독서기록">
    
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap');
        body { 
            font-family: 'Inter', sans-serif; 
            -webkit-tap-highlight-color: transparent; /* 모바일 터치 하이라이트 제거 */
        }
        .calendar-grid { display: grid; grid-template-columns: repeat(7, 1-fr); }
        .day-cell { min-height: 80px; }
        @media (min-width: 768px) {
            .day-cell { min-height: 100px; }
        }
        .spinner {
            border: 3px solid rgba(0, 0, 0, 0.1);
            width: 24px;
            height: 24px;
            border-radius: 50%;
            border-left-color: #4f46e5;
            animation: spin 1s linear infinite;
        }
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
        input::-webkit-outer-spin-button,
        input::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }
        .finished-list-scroll {
            display: flex;
            overflow-x: auto;
            gap: 1rem;
            padding-bottom: 0.5rem;
            -webkit-overflow-scrolling: touch; /* iOS 스크롤 부드럽게 */
        }
        .finished-list-scroll::-webkit-scrollbar {
            height: 4px;
        }
        .finished-list-scroll::-webkit-scrollbar-thumb {
            background: #fcd34d;
            border-radius: 10px;
        }
        /* 모바일 터치 타겟 최적화 */
        button, input, select, textarea {
            font-size: 16px !important; /* iOS 자동 줌 방지 */
        }
    </style>
</head>
<body class="bg-slate-50 min-h-screen text-slate-800 pb-12">

    <div class="max-w-6xl mx-auto p-4 md:p-8">
        <!-- Header -->
        <header class="mb-6 md:mb-8 text-center">
            <h1 class="text-2xl md:text-3xl font-bold text-indigo-600 mb-2">📚 나만의 독서 기록장</h1>
            <p class="text-slate-500 text-sm md:text-base">매일의 독서 습관을 기록하고 성장하세요.</p>
        </header>

        <!-- 상단 대시보드 (통계 및 목표) -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6 mb-6 md:mb-8">
            <div class="bg-white border border-slate-200 p-4 md:p-5 rounded-2xl shadow-sm flex flex-col justify-center">
                <div class="flex items-center gap-3 mb-2 text-slate-500 text-xs md:text-sm font-semibold">
                    <i class="fa-solid fa-chart-line text-indigo-500"></i> 이번 달 총 독서량
                </div>
                <div class="text-2xl md:text-3xl font-bold text-slate-800"><span id="totalMonthPages">0</span> <span class="text-lg font-normal text-slate-400">페이지</span></div>
            </div>
            
            <div class="bg-white border border-slate-200 p-4 md:p-5 rounded-2xl shadow-sm">
                <div class="flex items-center justify-between mb-2 text-slate-500 text-xs md:text-sm font-semibold">
                    <span><i class="fa-solid fa-bullseye text-red-500 mr-2"></i> 월간 완독 목표</span>
                    <button onclick="openGoalModal()" class="text-[10px] text-indigo-500 hover:underline">목표 수정</button>
                </div>
                <div class="flex items-end justify-between mb-1">
                    <span class="text-xl md:text-2xl font-bold text-slate-800"><span id="currentGoalCount">0</span> / <span id="targetGoalCount">5</span></span>
                    <span class="text-xs font-bold text-indigo-600" id="goalPercent">0%</span>
                </div>
                <div class="w-full bg-slate-100 h-2 rounded-full overflow-hidden">
                    <div id="goalProgressBar" class="bg-indigo-500 h-full transition-all duration-500" style="width: 0%"></div>
                </div>
            </div>

            <div class="bg-white border border-slate-200 p-4 md:p-5 rounded-2xl shadow-sm flex flex-col justify-center">
                <div class="flex items-center gap-3 mb-2 text-slate-500 text-xs md:text-sm font-semibold">
                    <i class="fa-solid fa-calendar-check text-green-500"></i> 연속 독서 일수
                </div>
                <div class="text-2xl md:text-3xl font-bold text-slate-800"><span id="streakDays">0</span> <span class="text-lg font-normal text-slate-400">일째</span></div>
            </div>
        </div>

        <!-- 이 달 완독한 책 섹션 -->
        <section class="mb-6 md:mb-8 bg-white border border-slate-200 rounded-2xl p-4 md:p-6 shadow-sm">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-lg md:text-xl font-bold text-slate-700 flex items-center gap-2">
                    <i class="fa-solid fa-crown text-amber-500"></i> <span id="summaryMonthText">5월</span> 완독 리스트
                </h2>
                <span id="finishedCountBadge" class="bg-amber-500 text-white text-[10px] md:text-xs font-bold px-3 py-1 rounded-full">0권 완독</span>
            </div>
            <div id="finishedBooksList" class="finished-list-scroll">
                <p class="text-slate-400 italic text-sm py-2">아직 완독한 책이 없습니다.</p>
            </div>
        </section>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 md:gap-8">
            <!-- Left Column: Input Form -->
            <div class="lg:col-span-1">
                <div class="bg-white p-5 md:p-6 rounded-2xl shadow-sm border border-slate-200 sticky top-8">
                    <h2 class="text-lg md:text-xl font-semibold mb-6 flex items-center gap-2">
                        <i class="fa-solid fa-pen-nib text-indigo-500"></i> 오늘 읽은 책 기록
                    </h2>
                    
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-slate-600 mb-1">책 제목</label>
                            <div class="relative">
                                <input type="text" id="bookTitle" placeholder="예: 어린 왕자" 
                                    onblur="autoFillStartPage()"
                                    onkeydown="if(event.key === 'Enter') searchAuthor()"
                                    class="w-full px-4 py-2.5 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none pr-12">
                                <button onclick="searchAuthor()" id="searchBtn" class="absolute right-2 top-1/2 -translate-y-1/2 bg-indigo-50 text-indigo-500 hover:bg-indigo-100 w-10 h-10 rounded-lg flex items-center justify-center">
                                    <i class="fa-solid fa-magnifying-glass"></i>
                                </button>
                            </div>
                        </div>

                        <div>
                            <div class="flex justify-between items-end mb-1">
                                <label class="block text-sm font-medium text-slate-600">작가</label>
                                <button id="manualSearchBtn" onclick="openKyoboSearch()" class="hidden text-[10px] text-indigo-500 hover:underline">
                                    직접 찾기 <i class="fa-solid fa-arrow-up-right-from-square text-[8px]"></i>
                                </button>
                            </div>
                            <div class="relative flex items-center">
                                <input type="text" id="bookAuthor" placeholder="작가 검색을 이용하세요" 
                                    class="w-full px-4 py-2.5 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none bg-slate-50">
                                <div id="authorLoading" class="hidden absolute right-3">
                                    <div class="spinner"></div>
                                </div>
                            </div>
                        </div>

                        <div>
                            <div class="flex justify-between items-center mb-1">
                                <label class="block text-sm font-medium text-slate-600">읽은 페이지 범위</label>
                                <span id="autoFillBadge" class="hidden text-[10px] bg-green-100 text-green-700 px-2 py-0.5 rounded-full font-bold animate-pulse">이전 기록 불러옴</span>
                            </div>
                            <div class="flex items-center justify-between gap-1 text-slate-500 font-bold">
                                <span>(</span>
                                <input type="number" id="startPage" placeholder="시작" 
                                    class="w-full px-2 py-2.5 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none text-center text-slate-800 font-normal">
                                <span>)</span>
                                <span class="mx-1">~</span>
                                <span>(</span>
                                <input type="number" id="endPage" placeholder="끝" 
                                    class="w-full px-2 py-2.5 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none text-center text-slate-800 font-normal">
                                <span>)</span>
                            </div>
                            <div class="flex items-center gap-2 mt-3 p-3 bg-indigo-50 rounded-xl border border-indigo-100">
                                <input type="checkbox" id="isFinished" class="w-5 h-5 text-indigo-600 border-slate-300 rounded focus:ring-indigo-500 cursor-pointer" onchange="toggleEndPageInput()">
                                <label for="isFinished" class="text-sm font-bold text-indigo-700 cursor-pointer select-none">이 책을 완독했습니다!</label>
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-slate-600 mb-1">오늘의 한 줄 평</label>
                            <textarea id="dailyNote" placeholder="감상을 남겨보세요" 
                                class="w-full px-4 py-2 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none h-20 resize-none text-sm"></textarea>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-slate-600 mb-1">날짜 선택</label>
                            <input type="date" id="logDate" 
                                class="w-full px-4 py-2.5 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none">
                        </div>

                        <button onclick="saveLog()" class="w-full bg-indigo-600 text-white font-bold py-4 rounded-xl hover:bg-indigo-700 shadow-lg shadow-indigo-100 transition duration-200 flex items-center justify-center gap-2 active:scale-[0.98]">
                            <i class="fa-solid fa-check"></i> 기록 저장하기
                        </button>
                    </div>
                    <div id="statusMsg" class="mt-4 text-center text-sm font-medium hidden p-2 rounded-lg"></div>
                </div>
            </div>

            <!-- Right Column: Calendar View -->
            <div class="lg:col-span-2">
                <div class="bg-white p-4 md:p-6 rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                    <div class="flex items-center justify-between mb-6">
                        <button onclick="changeMonth(-1)" class="w-10 h-10 flex items-center justify-center hover:bg-slate-100 rounded-full transition"><i class="fa-solid fa-chevron-left"></i></button>
                        <h2 id="currentMonthYear" class="text-lg md:text-xl font-bold text-slate-700">2024년 5월</h2>
                        <button onclick="changeMonth(1)" class="w-10 h-10 flex items-center justify-center hover:bg-slate-100 rounded-full transition"><i class="fa-solid fa-chevron-right"></i></button>
                    </div>

                    <div class="grid grid-cols-7 gap-px bg-slate-200 border border-slate-200 overflow-hidden rounded-2xl shadow-inner">
                        <div class="bg-slate-50 py-2 text-center text-[10px] md:text-xs font-bold text-red-400 uppercase">일</div>
                        <div class="bg-slate-50 py-2 text-center text-[10px] md:text-xs font-bold text-slate-500 uppercase">월</div>
                        <div class="bg-slate-50 py-2 text-center text-[10px] md:text-xs font-bold text-slate-500 uppercase">화</div>
                        <div class="bg-slate-50 py-2 text-center text-[10px] md:text-xs font-bold text-slate-500 uppercase">수</div>
                        <div class="bg-slate-50 py-2 text-center text-[10px] md:text-xs font-bold text-slate-500 uppercase">목</div>
                        <div class="bg-slate-50 py-2 text-center text-[10px] md:text-xs font-bold text-slate-500 uppercase">금</div>
                        <div class="bg-slate-50 py-2 text-center text-[10px] md:text-xs font-bold text-blue-400 uppercase">토</div>
                        
                        <div id="calendarDays" class="contents"></div>
                    </div>
                    
                    <div class="mt-8 pt-6 border-t border-slate-100 flex flex-wrap justify-center md:justify-end gap-4">
                        <button onclick="exportData()" class="text-xs text-slate-500 hover:text-indigo-600 flex items-center gap-1 p-2">
                            <i class="fa-solid fa-download"></i> 내 데이터 백업
                        </button>
                        <button onclick="document.getElementById('importFile').click()" class="text-xs text-slate-500 hover:text-indigo-600 flex items-center gap-1 p-2">
                            <i class="fa-solid fa-upload"></i> 데이터 복구
                        </button>
                        <input type="file" id="importFile" class="hidden" onchange="importData(event)">
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 상세 보기 모달 -->
    <div id="detailModal" class="fixed inset-0 bg-black/60 backdrop-blur-sm hidden flex items-center justify-center p-4 z-50">
        <div class="bg-white rounded-3xl max-w-xl w-full p-5 md:p-8 shadow-2xl max-h-[90vh] overflow-y-auto">
            <div class="flex justify-between items-start mb-6 sticky top-0 bg-white z-10 pb-4 border-b border-slate-100">
                <div>
                    <h3 id="modalDate" class="text-lg font-bold text-slate-700">기록 상세보기</h3>
                    <div id="modalBatchActions" class="hidden mt-3 flex items-center gap-3">
                        <label class="flex items-center gap-2 text-xs text-slate-500 cursor-pointer bg-slate-50 px-2 py-1 rounded-lg">
                            <input type="checkbox" id="selectAllLogs" onchange="toggleSelectAllLogs()" class="rounded-md text-indigo-600 w-4 h-4">
                            전체 선택
                        </label>
                        <button onclick="bulkDeleteLogs()" class="text-xs bg-red-50 text-red-600 px-3 py-1 rounded-lg border border-red-100 font-bold active:bg-red-100">
                            선택 삭제
                        </button>
                    </div>
                </div>
                <button onclick="closeModal()" class="w-10 h-10 flex items-center justify-center bg-slate-50 rounded-full text-slate-400 hover:text-slate-600"><i class="fa-solid fa-xmark text-xl"></i></button>
            </div>
            <div id="modalContent" class="space-y-5"></div>
        </div>
    </div>

    <!-- 목표 수정 모달 -->
    <div id="goalModal" class="fixed inset-0 bg-black/60 backdrop-blur-sm hidden flex items-center justify-center p-4 z-[60]">
        <div class="bg-white rounded-3xl max-w-xs w-full p-6 shadow-2xl">
            <h3 class="text-lg font-bold text-slate-700 mb-4">월간 목표 수정</h3>
            <div class="mb-6">
                <label class="block text-sm font-medium text-slate-600 mb-2">이번 달 완독 목표 (권)</label>
                <input type="number" id="newGoalInput" class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none text-center text-xl font-bold" min="1" max="100">
            </div>
            <div class="flex gap-3">
                <button onclick="closeGoalModal()" class="flex-1 bg-slate-100 text-slate-500 py-3 rounded-xl font-bold active:bg-slate-200 transition">취소</button>
                <button onclick="saveMonthlyGoal()" class="flex-2 bg-indigo-600 text-white py-3 px-6 rounded-xl font-bold active:bg-indigo-700 shadow-lg shadow-indigo-100 transition">변경</button>
            </div>
        </div>
    </div>

    <script>
        // --- Configurations & State ---
        const apiKey = ""; 
        let readingLogs = JSON.parse(localStorage.getItem('readingLogs')) || [];
        let readingGoal = parseInt(localStorage.getItem('readingGoal')) || 5;
        let currentDate = new Date();
        let openModalDate = null;
        let editingLogId = null; 

        // --- Core Functions ---
        async function fetchWithRetry(url, options, retries = 5, backoff = 1000) {
            try {
                const response = await fetch(url, options);
                if (!response.ok) {
                    const errorJson = await response.json().catch(() => ({}));
                    throw new Error(errorJson.error?.message || `API error (${response.status})`);
                }
                return await response.json();
            } catch (err) {
                if (retries > 0 && !err.message.includes("401")) {
                    await new Promise(resolve => setTimeout(resolve, backoff));
                    return fetchWithRetry(url, options, retries - 1, backoff * 2);
                }
                throw err;
            }
        }

        async function searchAuthor() {
            const title = document.getElementById('bookTitle').value.trim();
            if (!title) {
                showStatus('책 제목을 입력해 주세요.', 'error');
                return;
            }
            const authorInput = document.getElementById('bookAuthor');
            const loader = document.getElementById('authorLoading');
            const searchBtn = document.getElementById('searchBtn');
            const manualBtn = document.getElementById('manualSearchBtn');
            authorInput.value = '';
            authorInput.placeholder = '작가 검색 중...';
            loader.classList.remove('hidden');
            searchBtn.disabled = true;
            manualBtn.classList.add('hidden');
            const systemPrompt = `당신은 한국의 도서 정보 전문가입니다. 사용자가 제공한 책 제목에 해당하는 '원작 저자(작가)'를 정확하게 한 명만 찾아내야 합니다. 지은이 이름만 출력하세요.`;
            const userQuery = `책 제목 "${title}"의 작가(저자) 이름을 정확하게 알려줘.`;
            try {
                const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
                const result = await fetchWithRetry(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        contents: [{ parts: [{ text: userQuery }] }],
                        systemInstruction: { parts: [{ text: systemPrompt }] },
                        tools: [{ "google_search": {} }]
                    })
                });
                const authorName = result.candidates?.[0]?.content?.parts?.[0]?.text?.trim() || '정보 없음';
                authorInput.value = authorName.replace(/[*'"]/g, '');
                autoFillStartPage();
                showStatus('작가 정보를 확인했습니다.', 'success');
            } catch (error) {
                manualBtn.classList.remove('hidden');
                authorInput.placeholder = '직접 입력해주세요';
            } finally {
                loader.classList.add('hidden');
                searchBtn.disabled = false;
            }
        }

        function openKyoboSearch() {
            const title = document.getElementById('bookTitle').value.trim();
            if (title) {
                const url = `https://search.kyobobook.co.kr/search?keyword=${encodeURIComponent(title)}&gbCode=TOT&target=total`;
                window.open(url, '_blank');
            }
        }

        function autoFillStartPage() {
            const title = document.getElementById('bookTitle').value.trim();
            const startPageInput = document.getElementById('startPage');
            if (!title) return;
            const bookLogs = readingLogs.filter(log => log.title === title && !log.isFinished);
            if (bookLogs.length > 0) {
                const lastEndPage = Math.max(...bookLogs.map(log => log.endPage));
                if (lastEndPage > 0) {
                    startPageInput.value = lastEndPage + 1;
                    const badge = document.getElementById('autoFillBadge');
                    badge.classList.remove('hidden');
                    setTimeout(() => badge.classList.add('hidden'), 3000);
                }
            }
        }

        function toggleEndPageInput() {
            const isFinished = document.getElementById('isFinished').checked;
            const endPageInput = document.getElementById('endPage');
            if (isFinished) {
                endPageInput.disabled = true;
                endPageInput.placeholder = "완독";
                endPageInput.classList.add('bg-slate-100');
            } else {
                endPageInput.disabled = false;
                endPageInput.placeholder = "끝";
                endPageInput.classList.remove('bg-slate-100');
            }
        }

        function openGoalModal() {
            document.getElementById('newGoalInput').value = readingGoal;
            document.getElementById('goalModal').classList.remove('hidden');
        }
        function closeGoalModal() { document.getElementById('goalModal').classList.add('hidden'); }
        function saveMonthlyGoal() {
            const val = parseInt(document.getElementById('newGoalInput').value);
            if (!isNaN(val) && val > 0) {
                readingGoal = val;
                localStorage.setItem('readingGoal', readingGoal);
                renderUI();
                closeGoalModal();
                showStatus('목표가 수정되었습니다.', 'success');
            }
        }

        function saveLog() {
            const title = document.getElementById('bookTitle').value.trim();
            const author = document.getElementById('bookAuthor').value.trim();
            const startPageInput = document.getElementById('startPage').value;
            const endPageInput = document.getElementById('endPage').value;
            const isFinished = document.getElementById('isFinished').checked;
            const note = document.getElementById('dailyNote').value.trim();
            const date = document.getElementById('logDate').value;
            if (!title || !date) { showStatus('책 제목과 날짜를 확인해 주세요.', 'error'); return; }
            if (!isFinished && (!startPageInput || !endPageInput)) { showStatus('페이지 범위를 입력해 주세요.', 'error'); return; }
            const start = parseInt(startPageInput) || 0;
            const end = parseInt(endPageInput) || 0;
            const newLog = {
                id: Date.now(), title, author, startPage: start, endPage: end,
                totalPages: isFinished ? 0 : Math.max(0, end - start + 1),
                isFinished, note, date
            };
            readingLogs.push(newLog);
            localStorage.setItem('readingLogs', JSON.stringify(readingLogs));
            showStatus('저장되었습니다!', 'success');
            renderUI();
            document.getElementById('bookTitle').value = '';
            document.getElementById('bookAuthor').value = '';
            document.getElementById('startPage').value = '';
            document.getElementById('endPage').value = '';
            document.getElementById('dailyNote').value = '';
            document.getElementById('isFinished').checked = false;
            toggleEndPageInput();
        }

        function showStatus(msg, type) {
            const el = document.getElementById('statusMsg');
            el.innerText = msg;
            el.className = `mt-4 text-center text-sm font-bold p-2 rounded-xl transition ${type === 'success' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'}`;
            el.classList.remove('hidden');
            setTimeout(() => el.classList.add('hidden'), 4000);
        }

        // --- Render UI ---
        function renderUI() { renderCalendar(); renderFinishedSummary(); renderStats(); }

        function renderStats() {
            const year = currentDate.getFullYear();
            const month = currentDate.getMonth();
            const thisMonthLogs = readingLogs.filter(log => {
                const d = new Date(log.date);
                return d.getFullYear() === year && d.getMonth() === month;
            });
            const totalPages = thisMonthLogs.reduce((sum, log) => sum + (log.totalPages || 0), 0);
            document.getElementById('totalMonthPages').innerText = totalPages.toLocaleString();
            const finishedLogs = thisMonthLogs.filter(log => log.isFinished);
            const uniqueFinished = [...new Set(finishedLogs.map(l => l.title))].length;
            document.getElementById('currentGoalCount').innerText = uniqueFinished;
            document.getElementById('targetGoalCount').innerText = readingGoal;
            const progress = Math.min(100, Math.round((uniqueFinished / readingGoal) * 100));
            document.getElementById('goalProgressBar').style.width = progress + '%';
            document.getElementById('goalPercent').innerText = progress + '%';
            const dates = [...new Set(readingLogs.map(l => l.date))].sort();
            let streak = 0;
            if (dates.length > 0) {
                const todayStr = new Date().toISOString().split('T')[0];
                let checkDate = new Date(dates[dates.length - 1]);
                if ((new Date(todayStr) - checkDate) / (1000 * 60 * 60 * 24) <= 1) {
                    streak = 1;
                    for (let i = dates.length - 2; i >= 0; i--) {
                        const prevDate = new Date(dates[i]);
                        if ((checkDate - prevDate) / (1000 * 60 * 60 * 24) === 1) { streak++; checkDate = prevDate; } else { break; }
                    }
                }
            }
            document.getElementById('streakDays').innerText = streak;
        }

        function renderFinishedSummary() {
            const year = currentDate.getFullYear();
            const month = currentDate.getMonth();
            document.getElementById('summaryMonthText').innerText = `${month + 1}월`;
            const finishedLogs = readingLogs.filter(log => {
                const d = new Date(log.date);
                return d.getFullYear() === year && d.getMonth() === month && log.isFinished;
            });
            const unique = []; const titles = new Set();
            finishedLogs.forEach(l => { if (!titles.has(l.title)) { unique.push(l); titles.add(l.title); } });
            document.getElementById('finishedCountBadge').innerText = `${unique.length}권 완독`;
            const list = document.getElementById('finishedBooksList');
            if (unique.length === 0) { list.innerHTML = '<p class="text-slate-400 italic text-xs py-2">아직 완독한 책이 없습니다.</p>'; return; }
            list.innerHTML = unique.map(log => `
                <div class="flex-shrink-0 bg-slate-50 border border-amber-100 p-4 rounded-2xl w-44 transition active:scale-95 shadow-sm">
                    <div class="flex items-center justify-between mb-2">
                        <span class="text-amber-500 text-[9px] font-bold uppercase tracking-widest">Completed</span>
                        <i class="fa-solid fa-star text-amber-400 text-xs"></i>
                    </div>
                    <h4 class="font-bold text-slate-800 text-sm truncate">${log.title}</h4>
                    <p class="text-[10px] text-slate-500 truncate">${log.author}</p>
                </div>
            `).join('');
        }

        function renderCalendar() {
            const year = currentDate.getFullYear();
            const month = currentDate.getMonth();
            document.getElementById('currentMonthYear').innerText = `${year}년 ${month + 1}월`;
            const firstDay = new Date(year, month, 1).getDay();
            const daysInMonth = new Date(year, month + 1, 0).getDate();
            const container = document.getElementById('calendarDays');
            container.innerHTML = '';
            for (let i = 0; i < firstDay; i++) {
                const empty = document.createElement('div');
                empty.className = 'bg-white day-cell opacity-50 border-r border-b border-slate-100';
                container.appendChild(empty);
            }
            for (let day = 1; day <= daysInMonth; day++) {
                const dateStr = `${year}-${String(month + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
                const logs = readingLogs.filter(log => log.date === dateStr);
                const cell = document.createElement('div');
                cell.className = `bg-white day-cell p-1 md:p-2 border-r border-b border-slate-100 flex flex-col hover:bg-indigo-50/50 transition cursor-pointer relative overflow-hidden active:bg-indigo-100`;
                cell.onclick = () => { editingLogId = null; openModal(dateStr, logs); };
                const dayNum = document.createElement('span');
                const isTodayDate = new Date().toISOString().split('T')[0] === dateStr;
                dayNum.className = `text-xs md:text-sm font-bold ${isTodayDate ? 'bg-indigo-600 text-white w-6 h-6 flex items-center justify-center rounded-full' : 'text-slate-500'}`;
                dayNum.innerText = day;
                cell.appendChild(dayNum);
                const logContainer = document.createElement('div');
                logContainer.className = 'mt-1 space-y-1 overflow-hidden';
                logs.slice(0, 3).forEach(log => {
                    const label = document.createElement('div');
                    label.className = `text-[8px] md:text-[9px] ${log.isFinished ? 'bg-amber-100 text-amber-700' : 'bg-indigo-100 text-indigo-700'} px-1 rounded truncate leading-tight py-0.5 font-bold`;
                    label.innerText = log.title;
                    logContainer.appendChild(label);
                });
                if (logs.length > 3) {
                    const more = document.createElement('div');
                    more.className = 'text-[8px] text-slate-400 text-center font-bold';
                    more.innerText = `+${logs.length - 3}`;
                    logContainer.appendChild(more);
                }
                cell.appendChild(logContainer);
                container.appendChild(cell);
            }
        }

        function changeMonth(delta) { currentDate.setMonth(currentDate.getMonth() + delta); renderUI(); }

        function openModal(date, logs) {
            openModalDate = date;
            document.getElementById('modalDate').innerText = `${date} 독서 기록`;
            const content = document.getElementById('modalContent');
            const batch = document.getElementById('modalBatchActions');
            if (logs.length === 0) {
                content.innerHTML = '<div class="text-center py-12"><i class="fa-solid fa-book-open text-slate-200 text-5xl mb-4"></i><p class="text-slate-400 italic">기록된 활동이 없습니다.</p></div>';
                batch.classList.add('hidden');
            } else {
                batch.classList.remove('hidden');
                document.getElementById('selectAllLogs').checked = false;
                content.innerHTML = logs.map(log => {
                    if (editingLogId === log.id) {
                        return `
                        <div class="bg-indigo-50/50 p-5 rounded-3xl border-2 border-indigo-200 shadow-inner">
                            <div class="space-y-4">
                                <input type="text" id="editTitle_${log.id}" value="${log.title}" class="w-full text-base font-bold bg-white rounded-xl px-4 py-2 border border-indigo-100 focus:outline-none focus:ring-2 focus:ring-indigo-500 shadow-sm">
                                <input type="text" id="editAuthor_${log.id}" value="${log.author}" class="w-full text-sm bg-white rounded-xl px-4 py-2 border border-slate-200 focus:outline-none">
                                <div class="flex items-center gap-2">
                                    <input type="number" id="editStart_${log.id}" value="${log.startPage}" class="w-1/2 text-sm bg-white rounded-xl px-3 py-2 border border-slate-200">
                                    <span class="text-slate-400 font-bold">~</span>
                                    <input type="number" id="editEnd_${log.id}" value="${log.endPage}" ${log.isFinished ? 'disabled' : ''} class="w-1/2 text-sm bg-white rounded-xl px-3 py-2 border border-slate-200">
                                </div>
                                <textarea id="editNote_${log.id}" class="w-full text-sm bg-white border border-slate-200 rounded-xl p-3 h-20 resize-none">${log.note || ''}</textarea>
                                <div class="flex items-center justify-between">
                                    <label class="flex items-center gap-2 text-sm font-bold text-indigo-700">
                                        <input type="checkbox" id="editFinished_${log.id}" ${log.isFinished ? 'checked' : ''} onchange="const end = document.getElementById('editEnd_${log.id}'); end.disabled = this.checked; if(this.checked) end.value=0;"> 완독
                                    </label>
                                    <div class="flex gap-2">
                                        <button onclick="cancelEdit()" class="px-4 py-2 bg-slate-200 text-slate-600 rounded-xl text-xs font-bold">취소</button>
                                        <button onclick="saveEdit(${log.id})" class="px-5 py-2 bg-indigo-600 text-white rounded-xl text-xs font-bold shadow-lg shadow-indigo-100">저장</button>
                                    </div>
                                </div>
                            </div>
                        </div>`;
                    }
                    const pageDisp = log.isFinished ? (log.startPage > 0 ? `p.${log.startPage} ~ 완독` : '완독') : `p.${log.startPage} ~ p.${log.endPage}`;
                    return `
                    <div class="bg-white p-5 rounded-3xl border border-slate-100 shadow-sm relative group active:bg-slate-50 transition">
                        <div class="flex justify-between items-start mb-3">
                            <div class="pr-12">
                                <h4 class="font-bold text-slate-800 text-lg flex items-center gap-2">${log.title} ${log.isFinished ? '⭐' : ''}</h4>
                                <p class="text-sm text-slate-500">${log.author}</p>
                            </div>
                            <div class="flex items-center gap-1">
                                <input type="checkbox" name="logSelect" value="${log.id}" class="w-5 h-5 rounded-full border-slate-300 text-indigo-600 mr-2">
                                <button onclick="startEdit(${log.id})" class="w-9 h-9 flex items-center justify-center bg-slate-50 text-slate-400 rounded-full active:bg-indigo-50 active:text-indigo-600 transition"><i class="fa-solid fa-pen-to-square"></i></button>
                                <button onclick="deleteLog(${log.id})" class="w-9 h-9 flex items-center justify-center bg-slate-50 text-slate-400 rounded-full active:bg-red-50 active:text-red-500 transition"><i class="fa-solid fa-trash-can"></i></button>
                            </div>
                        </div>
                        ${log.note ? `<div class="bg-slate-50/50 p-3 rounded-2xl text-sm text-slate-600 italic mb-4 border-l-4 border-indigo-200">"${log.note}"</div>` : ''}
                        <div class="flex justify-between items-center mt-2">
                            <span class="text-xs font-bold text-slate-400 bg-slate-100 px-3 py-1 rounded-full">${pageDisp}</span>
                            <div class="text-xs font-bold ${log.isFinished ? 'text-amber-500 bg-amber-50' : 'text-indigo-600 bg-indigo-50'} px-3 py-1 rounded-full">
                                ${log.isFinished ? 'COMPLETED' : `+${log.totalPages}p`}
                            </div>
                        </div>
                    </div>`;
                }).join('');
            }
            document.getElementById('detailModal').classList.remove('hidden');
        }

        function closeModal() { document.getElementById('detailModal').classList.add('hidden'); openModalDate = null; editingLogId = null; }
        function startEdit(id) { editingLogId = id; const logs = readingLogs.filter(log => log.date === openModalDate); openModal(openModalDate, logs); }
        function cancelEdit() { editingLogId = null; const logs = readingLogs.filter(log => log.date === openModalDate); openModal(openModalDate, logs); }
        function saveEdit(id) {
            const title = document.getElementById(`editTitle_${id}`).value.trim();
            const author = document.getElementById(`editAuthor_${id}`).value.trim();
            const start = parseInt(document.getElementById(`editStart_${id}`).value) || 0;
            const isFinished = document.getElementById(`editFinished_${id}`).checked;
            const end = isFinished ? 0 : (parseInt(document.getElementById(`editEnd_${id}`).value) || 0);
            const note = document.getElementById(`editNote_${id}`).value.trim();
            const idx = readingLogs.findIndex(l => l.id === id);
            if (idx !== -1) {
                readingLogs[idx] = { ...readingLogs[idx], title, author, startPage: start, endPage: end, isFinished, note, totalPages: isFinished ? 0 : Math.max(0, end - start + 1) };
                localStorage.setItem('readingLogs', JSON.stringify(readingLogs));
                editingLogId = null; renderUI(); openModal(openModalDate, readingLogs.filter(l => l.date === openModalDate));
            }
        }
        function deleteLog(id) { readingLogs = readingLogs.filter(log => log.id !== id); localStorage.setItem('readingLogs', JSON.stringify(readingLogs)); renderUI(); openModal(openModalDate, readingLogs.filter(l => l.date === openModalDate)); }
        function toggleSelectAllLogs() { const selectAll = document.getElementById('selectAllLogs').checked; document.querySelectorAll('input[name="logSelect"]').forEach(cb => cb.checked = selectAll); }
        function bulkDeleteLogs() {
            const ids = Array.from(document.querySelectorAll('input[name="logSelect"]:checked')).map(cb => parseInt(cb.value));
            if (ids.length === 0) return;
            readingLogs = readingLogs.filter(log => !ids.includes(log.id));
            localStorage.setItem('readingLogs', JSON.stringify(readingLogs));
            renderUI(); openModal(openModalDate, readingLogs.filter(l => l.date === openModalDate));
        }

        function exportData() {
            const dataStr = JSON.stringify({ logs: readingLogs, goal: readingGoal });
            const dataUri = 'data:application/json;charset=utf-8,'+ encodeURIComponent(dataStr);
            const link = document.createElement('a'); link.setAttribute('href', dataUri); link.setAttribute('download', 'reading_backup.json'); link.click();
        }
        function importData(e) {
            const file = e.target.files[0]; if (!file) return;
            const reader = new FileReader();
            reader.onload = function(ev) {
                try {
                    const data = JSON.parse(ev.target.result);
                    if (data.logs) { readingLogs = data.logs; readingGoal = data.goal || 5; localStorage.setItem('readingLogs', JSON.stringify(readingLogs)); localStorage.setItem('readingGoal', readingGoal); renderUI(); alert("데이터가 복구되었습니다."); }
                } catch(e) { alert("잘못된 파일입니다."); }
            };
            reader.readAsText(file);
        }

        window.onload = () => {
            const today = new Date().toISOString().split('T')[0];
            document.getElementById('logDate').value = today;
            renderUI();
        };
    </script>
</body>
</html>
